function buildSwatches() {
  const bar = document.getElementById('swatchBar');
  items.forEach(item => {
    const s = document.createElement('div');
    s.className = 'swatch';
    s.style.background = CAT_COLORS[item.cat];
    bar.appendChild(s);
  });
}
function badge(cat) {
  return `<span class="cat-badge" style="background:${CAT_COLORS[cat]}">${CAT_LABELS[cat]}</span>`;
}
function renderTable(filter) {
  const tbody = document.getElementById('trackerBody');
  tbody.innerHTML = '';
  const visible = filter === 'all' ? items : items.filter(i => i.cat === filter);
  document.getElementById('visibleCount').textContent = visible.length;
  document.getElementById('noResults').style.display = visible.length === 0 ? 'block' : 'none';
  visible.forEach(item => {
    const isNA = ['Not disclosed','Under research','Not applicable'].includes(item.revenue);
    const tr = document.createElement('tr');
    tr.dataset.id = item.id;
    tr.innerHTML = `
      <td><span class="expand-icon">&#9654;</span>${String(item.id).padStart(2,'0')}</td>
      <td><div class="item-name">${item.name}</div><div class="item-preview">${item.preview}</div></td>
      <td>${badge(item.cat)}</td>
      <td class="col-change"><span class="change-val">${item.change}</span></td>
      <td class="col-effective"><span class="effective-val">${item.effective}</span></td>
      <td class="col-revenue"><span class="revenue-val${isNA?' revenue-na':''}">${item.revenue}</span></td>
      <td><span class="source-val">${item.source}</span></td>
    `;
    const expandTr = document.createElement('tr');
    expandTr.className = 'expand-row';
    expandTr.innerHTML = `<td colspan="7"><p>${item.details}</p></td>`;
    tr.addEventListener('click', () => {
      const open = tr.classList.contains('is-open');
      tr.classList.toggle('is-open', !open);
      expandTr.style.display = open ? 'none' : 'table-row';
    });
    tbody.appendChild(tr);
    tbody.appendChild(expandTr);
  });
}
document.querySelectorAll('.cat-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    renderTable(chip.dataset.cat);
  });
});
buildSwatches();
renderTable('all');
</script>
