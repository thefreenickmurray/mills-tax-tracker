<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;800;900&family=Lora:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #FFFFFF;
  --bg2:       #F7F7F5;
  --bg3:       #EEECEA;
  --text:      #1A1A1A;
  --muted:     #6B7280;
  --border:    #E2E0DC;
  --red:       #C8281F;
  --gold:      #9A6F1A;
  --cat-consumer: #B45309;
  --cat-income:   #B91C1C;
  --cat-payroll:  #7C3AED;
  --cat-business: #1D4ED8;
  --cat-healthcare:#0F766E;
  --cat-fee:      #4F46E5;
  --cat-fiscal:   #374151;
  --radius:    5px;
  --mono: 'IBM Plex Mono', monospace;
  --serif: 'Lora', Georgia, serif;
  --cond: 'Barlow Condensed', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--serif);
  font-size: 16px;
  line-height: 1.6;
}
a { color: var(--gold); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ===== MASTHEAD ===== */
.masthead {
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--red);
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.masthead-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 2rem;
  height: 56px;
}
.masthead-brand {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
}
.masthead-count {
  font-family: var(--cond);
  font-weight: 900;
  font-size: 2.2rem;
  line-height: 1;
  color: var(--red);
  letter-spacing: -0.02em;
}
.masthead-title {
  font-family: var(--cond);
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text);
  line-height: 1.2;
}
.masthead-title span { color: var(--muted); display: block; font-weight: 400; }
.masthead-stats {
  display: flex;
  gap: 0;
  align-items: center;
}
.mstat {
  display: flex;
  flex-direction: column;
  align-items: center;
  border-left: 1px solid var(--border);
  padding: 0 1.25rem;
}
.mstat-val {
  font-family: var(--cond);
  font-weight: 800;
  font-size: 1.05rem;
  line-height: 1;
  color: var(--red);
}
.mstat-label {
  font-family: var(--cond);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}
.masthead-nav {
  display: flex;
  gap: 1.5rem;
  font-family: var(--cond);
  font-size: 0.78rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.masthead-nav a { color: var(--muted); transition: color 0.2s; }
.masthead-nav a:hover { color: var(--text); text-decoration: none; }

/* ===== SWATCH BAR ===== */
.swatch-bar { height: 4px; display: flex; gap: 2px; }
.swatch { flex: 1; }

/* ===== FILTER BAR ===== */
.filter-bar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 60px;
  z-index: 50;
}
.filter-bar-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0.55rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.cat-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.cat-chip {
  font-family: var(--cond);
  font-size: 0.73rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 0.25rem 0.7rem;
  border-radius: 20px;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 0.12s;
  user-select: none;
  line-height: 1.4;
}
.cat-chip.active { color: #fff; }
.cat-chip:not(.active) { background: #fff; color: var(--muted); border-color: var(--border); }
.cat-chip:not(.active):hover { color: var(--text); border-color: #aaa; }
.cat-chip[data-cat="all"].active      { background: var(--red); border-color: var(--red); }
.cat-chip[data-cat="consumer"].active  { background: var(--cat-consumer); border-color: var(--cat-consumer); }
.cat-chip[data-cat="income"].active    { background: var(--cat-income); border-color: var(--cat-income); }
.cat-chip[data-cat="payroll"].active   { background: var(--cat-payroll); border-color: var(--cat-payroll); }
.cat-chip[data-cat="business"].active  { background: var(--cat-business); border-color: var(--cat-business); }
.cat-chip[data-cat="healthcare"].active{ background: var(--cat-healthcare); border-color: var(--cat-healthcare); }
.cat-chip[data-cat="fee"].active       { background: var(--cat-fee); border-color: var(--cat-fee); }
.cat-chip[data-cat="fiscal"].active    { background: var(--cat-fiscal); border-color: var(--cat-fiscal); }
.filter-count {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--muted);
  white-space: nowrap;
}
.filter-count span { color: var(--text); font-weight: 500; }

/* ===== TABLE ===== */
.table-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem 2rem;
}
table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
thead th {
  font-family: var(--cond);
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 0.65rem 0.75rem;
  text-align: left;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
  position: sticky;
  top: 93px;
  z-index: 10;
  white-space: nowrap;
}
thead th:first-child { width: 44px; }
tbody tr {
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.1s;
}
tbody tr:hover { background: var(--bg2); }
tbody tr.is-open { background: #FEF9F0; }
td { padding: 0.7rem 0.75rem; vertical-align: top; }
td:first-child {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--muted);
  white-space: nowrap;
  padding-top: 0.85rem;
}
.item-name {
  font-family: var(--serif);
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
  margin-bottom: 0.15rem;
}
.item-preview {
  font-family: var(--serif);
  font-style: italic;
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.4;
}
.cat-badge {
  display: inline-block;
  font-family: var(--cond);
  font-size: 0.63rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.18rem 0.5rem;
  border-radius: 3px;
  color: #fff;
  white-space: nowrap;
}
.change-val { font-family: var(--mono); font-size: 0.75rem; color: var(--text); line-height: 1.45; }
.effective-val { font-family: var(--mono); font-size: 0.74rem; color: var(--muted); white-space: nowrap; }
.revenue-val { font-family: var(--mono); font-size: 0.74rem; color: var(--gold); }
.revenue-na { color: var(--muted); }
.source-val { font-family: var(--mono); font-size: 0.68rem; color: var(--muted); line-height: 1.5; }
.expand-row { display: none; }
.expand-row td {
  background: #FFFDF7;
  padding: 0.9rem 0.9rem 0.9rem 3rem;
  border-bottom: 2px solid var(--border);
}
.expand-row p {
  font-family: var(--serif);
  font-size: 0.85rem;
  color: #4B5563;
  line-height: 1.75;
  max-width: 720px;
}
.expand-row p strong { color: var(--text); }
.expand-icon {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--muted);
  transition: transform 0.15s;
  display: inline-block;
  margin-right: 4px;
}
.is-open .expand-icon { transform: rotate(90deg); color: var(--red); }
.no-results {
  text-align: center; padding: 3rem;
  font-family: var(--serif); font-style: italic; color: var(--muted); display: none;
}

/* ===== LOWER ===== */
.lower-sections {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem 3rem;
  border-top: 1px solid var(--border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: start;
}
.design-prompt-box {
  background: #FFFDF3;
  border: 1px dashed #C9A84C;
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
}
.design-prompt-box h3 {
  font-family: var(--cond);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.85rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.design-prompt-box h3::before {
  content: '';
  display: inline-block;
  width: 5px; height: 5px;
  background: var(--gold);
  border-radius: 50%;
}
.design-prompt-box p { font-size: 0.82rem; color: var(--muted); line-height: 1.6; margin-bottom: 0.85rem; }
.prompt-code {
  background: #1A1A1A;
  border-radius: 4px;
  padding: 0.85rem 1rem;
  font-family: var(--mono);
  font-size: 0.72rem;
  color: #C9B67E;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}
.sources-box {
  padding: 1.25rem 1.5rem;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}
.sources-box h3 {
  font-family: var(--cond);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.75rem;
}
.sources-box p { font-size: 0.8rem; color: var(--muted); line-height: 1.8; margin-bottom: 0.6rem; }

/* ===== FOOTER ===== */
footer {
  border-top: 1px solid var(--border);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--cond);
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--muted);
  max-width: 1200px;
  margin: 0 auto;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .masthead-stats { display: none; }
  .lower-sections { grid-template-columns: 1fr; }
  .col-revenue { display: none; }
}
@media (max-width: 680px) {
  .col-effective { display: none; }
  .masthead-inner { grid-template-columns: auto 1fr; }
  .masthead-nav { display: none; }
}
@media (max-width: 480px) { .col-change { display: none; } }
</style>
</head>
