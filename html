  var state = { q:'', chamber:'all', party:'all' };
  function pc(p){ return (p==='D'||p==='R') ? p : (p==='U' ? 'U' : 'I'); }
  function cell(v, bill, first){
    var cls = ['vote']; if (first) cls.push('bill');
    var inner = '', title = '';
    if (v==='Y'){ cls.push('yes'); inner='<span class="x">✕</span>'; title='Yea — voted for '+bill.label; }
    else if (v==='N'){ inner='<span class="dot">·</span>'; title='Nay'; }
    else if (v==='X'){ inner='<span class="novote">–</span>'; title='Absent'; }
    else if (v==='E'){ inner='<span class="novote">–</span>'; title='Excused'; }
    else { cls.push('notseated'); title='Not seated for this vote'; }
    return '<td class="'+cls.join(' ')+'" title="'+title+'">'+inner+'</td>';
  }
  function render(){
    var bills = VOTING_DATA.bills, q = state.q.toLowerCase();
    var rows = VOTING_DATA.legislators.filter(function(r){
      if (state.chamber!=='all' && r.chamber!==state.chamber) return false;
      if (state.party!=='all'){
        if (state.party==='I'){ if (r.party==='D'||r.party==='R') return false; }
        else if (r.party!==state.party) return false;
      }
      if (q && !(r.disp.toLowerCase().indexOf(q)>=0 || r.town.toLowerCase().indexOf(q)>=0)) return false;
      return true;
    });
    var html = '', lastCh = null;
    rows.forEach(function(r){
      if (state.chamber==='all' && r.chamber!==lastCh){
        lastCh = r.chamber;
        html += '<tr class="divider"><td class="sticky-col" colspan="'+(bills.length+2)+'">'+(r.chamber==='House'?'House of Representatives':'Senate')+'</td></tr>';
      }
      var yes=0, tot=0, cells='';
      bills.forEach(function(b,i){ var v=r.votes[b.key]; if (v){ tot++; if (v==='Y') yes++; } cells += cell(v,b,i===0); });
      var score = tot ? (yes+'<span class="of">/'+tot+'</span>') : '<span class="of">—</span>';
      var dist = r.district ? ' '+r.district : '';
      html += '<tr><td class="sticky-col" style="text-align:left">'
        + '<div class="leg-name">'+r.disp+'</div>'
        + '<div class="leg-meta"><span class="party '+pc(r.party)+'">'+r.party+'</span>'
        + '<span class="chamber-tag">'+(r.chamber==='House'?'House':'Senate')+dist+'</span> · '+r.town+'</div>'
