  { id:4,  cat:'consumer',   name:'Cannabis Sales Tax',                          preview:'Adult-use sales tax raised 40%.',                                                                  change:'10% &#8594; 14% (+40%)',                           effective:'Jan 1, 2026',        revenue:'~$7.7M/yr',     source:'PL 2025, c. 388, Part F',           details:'The adult-use cannabis sales tax rate increased from 10% to 14%, a 40% rate increase. Cannabis excise taxes on specific products were separately reduced, but the overall sales tax rate on adult-use purchases increased. Projected revenue: roughly $15.4M over the biennium.' },
  { id:5,  cat:'consumer',   name:'Real Estate Transfer Tax (sales over $1M)',   preview:'Rate nearly tripled on the portion of sales above $1 million.',                                  change:'$2.20 &#8594; $6.00 per $500 (+173%)',             effective:'Nov 1, 2025',        revenue:'Not disclosed', source:'PL 2025, c. 388, Part V',            details:'The transfer tax rate on property value exceeding $1 million increased from $2.20 per $500 to $6.00 per $500. Thirty percent of new revenue routed to the Maine State Housing Authority. More than 1,000 Maine homes sold for $1 million or more in 2024.' },
  { id:6,  cat:'consumer',   name:'Service Provider Tax Base Expanded',          preview:'Cable, telecom, fabrication services folded into standard sales tax; new digital services captured.',change:'6% SPT repealed; base expanded into 5.5% sales tax',effective:'Jan 1, 2026',      revenue:'Not disclosed', source:'PL 2025, c. 388',                    details:'The 6% Service Provider Tax on cable/satellite, telecom, fabrication, and rental-purchase agreements was repealed and folded into the 5.5% standard sales and use tax. Net effect: the rate dropped 0.5% on services already taxed, but the base expanded to capture streaming and other digital services not previously covered.' },
  { id:7,  cat:'consumer',   name:'Lease-Stream Taxation Timing Changed',        preview:'Sales tax on leased property now applies to each periodic payment rather than upfront.',          change:'Taxation: upfront &#8594; periodic payments',      effective:'See source',         revenue:'Not disclosed', source:'PL 2025, c. 388',                    details:'Sales tax on leased or rented tangible personal property now applies to each periodic payment rather than to the upfront purchase price. This changes when and how the tax is collected on lease and rental transactions.' },
  { id:8,  cat:'consumer',   name:'Tobacco Products Definition Expanded',        preview:'Synthetic nicotine products captured before the 2026 rate hike.',                                 change:'Definition expanded to include synthetic nicotine', effective:'Aug 9, 2024',        revenue:'Not disclosed', source:'PL 2023, c. 613',                    details:'The definition of "tobacco products" was amended to include products containing nicotine whether natural or artificial. This captured synthetic nicotine products under Maine\'s tobacco tax before the 2026 rate increase took effect.' },
  { id:9,  cat:'income',     name:'2% Income Tax Surcharge on Income Over $1M',  preview:'New top marginal rate 9.15%. Retroactive to Jan 1, 2026. PTET carve-out for business owners.',   change:'7.15% &#8594; 9.15% (on income over $1M)',        effective:'Jan 1, 2026 (retro)', revenue:'~$74M/yr',      source:'LD 2212 (signed Apr 10, 2026)',      details:'A new 2% surcharge on income above $1 million, taking Maine\'s top marginal rate from 7.15% to 9.15%, retroactive to January 1, 2026. About 2,600 filers affected. Pass-through business owners (S-corps, partnerships) can elect Maine\'s Pass-Through Entity Tax (PTET) at 7.15%, avoiding the 2% surcharge personally. The surcharge falls hardest on W-2 wage earners without access to the PTET election.' },
  { id:10, cat:'payroll',    name:'Paid Family and Medical Leave: New 1% Payroll Tax', preview:'Broadest new tax on working Mainers. Benefits available May 1, 2026, after 16 months of paying in.', change:'New 1% payroll tax (0.5% employer / 0.5% employee)', effective:'Jan 1, 2025', revenue:'Not disclosed', source:'Maine PFML Act',              details:'Maine\'s PFML program imposes a 1% payroll tax on wages up to the Social Security wage base ($176,100 in 2025). For employers with 15+ employees: 0.5% each. For employers with fewer than 15: only the employee\'s 0.5% is required. Tax began collecting January 1, 2025; benefits did not become available until May 1, 2026, a 16-month gap.' },
  { id:11, cat:'business',   name:'BETR Eliminated for Retail Property',          preview:'Business Equipment Tax Reimbursement sunsetted for retail.',                                      change:'100% &#8594; 50% (CY2027), then 0% (CY2028+)',    effective:'CY2027',             revenue:'Not disclosed', source:'LD 2212',                             details:'The 2026 supplemental budget sunsets the Business Equipment Tax Reimbursement (BETR) program for retail property. Reimbursement drops to 50% for taxes paid on retail property in CY2027, and falls to zero for taxes paid in CY2028 and after.' },
